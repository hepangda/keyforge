# syntax=docker/dockerfile:1.7
#
# Development container: source mounted from the host, air watches files and
# rebuilds keyforge on change. Use docker-compose.yml; do NOT push this image.

FROM golang:1.26-alpine

RUN apk add --no-cache git curl bash ca-certificates make tzdata \
    && go install github.com/air-verse/air@latest

WORKDIR /src
EXPOSE 8080 9090

CMD ["air", "-c", ".air.toml"]
